### VARIABLES GLOBALES
# Usamos localhost para desarrollo. En producción, cambiarías esta URL.
@api_url = http://localhost:3000/api

############################################################
# TRABAJO INTEGRADOR: API de Productos Electrónicos
############################################################

### 1. OBTENER TODO EL CATÁLOGO
# Prueba la conexión inicial y el ordenamiento (por defecto debería ser por código).
GET {{api_url}}/productos
Accept: application/json

### 2. BUSCAR POR CÓDIGO (EXISTENTE)
# '1' es un Path Parameter. Verifica que el Service filtre correctamente.
GET {{api_url}}/productos/1
Accept: application/json

### 2.1 BUSCAR POR CÓDIGO (INEXISTENTE)
# Test de manejo de errores: Debería devolver un 404 y un mensaje claro.
GET {{api_url}}/productos/9999
Accept: application/json

### 3. CREAR UN NUEVO PRODUCTO (MANUAL)
# Verifica que el Schema de Mongoose valide los campos requeridos.
POST {{api_url}}/productos
Content-Type: application/json

{
    "codigo": 101,
    "nombre": "Teclado Luminoso RGB Pro",
    "precio": 65.50,
    "categoria": ["Accesorios", "Computación", "Gaming"],
    "descripcion": "Teclado mecánico con switches blue y retroiluminación."
}

### 4. ACTUALIZAR UN PRODUCTO (PUT)
# Modifica solo el precio. Verifica la lógica de 'findByIdAndUpdate' o similar.
PUT {{api_url}}/productos/101
Content-Type: application/json

{
    "precio": 59.99
}

### 5. ELIMINAR UN PRODUCTO
# Borra el registro de la base de datos.
DELETE {{api_url}}/productos/101
Accept: application/json


############################################################
# FILTROS Y OPERACIONES ESPECIALES
############################################################

### 6. BUSCADOR POR TÉRMINO (QUERY PARAMS)
# Usa el parámetro '?q=' para buscar coincidencias parciales en el nombre.
GET {{api_url}}/productos/buscar?q=Samsung
Accept: application/json

### 7. FILTRAR POR CATEGORÍA
# Verifica la búsqueda dentro del array de categorías de MongoDB.
GET {{api_url}}/productos/categoria/Celulares
Accept: application/json

### 8. FILTRAR POR RANGO DE PRECIO
# El formato esperado es 'min-max'. Verifica la lógica del operador $gte y $lte.
GET {{api_url}}/productos/precio/100-500
Accept: application/json

### 9. CARGA MASIVA (ARRAY DE OBJETOS)
# Este endpoint es vital para poblar la DB rápidamente al inicio.
POST {{api_url}}/productos/masivo
Content-Type: application/json

[
    {
        "codigo": 201,
        "nombre": "Monitor Gamer 27 pulgadas",
        "precio": 399.99,
        "categoria": ["Monitores", "Gaming"]
    },
    {
        "codigo": 202,
        "nombre": "Silla Gamer Ergonómica",
        "precio": 249.50,
        "categoria": ["Mobiliario", "Gaming"]
    }
]
